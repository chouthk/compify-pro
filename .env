# ===== AI Provider Configuration =====
# Set to "deepseek" to use DeepSeek API, or "lovable" for Lovable Gateway
AI_PROVIDER=deepseek

# DeepSeek API — 性價比高，香港無區域限制
# 去 https://platform.deepseek.com 註冊並取得 API Key
# DeepSeek 收費約 ¥0.5 / 百萬 tokens（輸入）+ ¥2 / 百萬 tokens（輸出）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Lovable Gateway (legacy — 如果你仲有 Lovable subscription 先用)
# LOVABLE_API_KEY=your-lovable-api-key
